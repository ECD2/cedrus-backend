# ── Server ──────────────────────────────────────────────
PORT=3000
# Environment. Set to `production` on Railway. In production the app refuses to
# boot if the Twilio signature bypass is on or PUBLIC_BASE_URL is unset.
NODE_ENV=development
# REQUIRED when VALIDATE_TWILIO_SIGNATURE is on: the public URL the signed
# webhook URL is built from. The signed URL is NEVER derived from the Host
# header (spoofable). Also used for the Twilio delivery-status callback.
PUBLIC_BASE_URL=https://your-app.up.railway.app
DEFAULT_TIMEZONE=America/New_York
ENABLE_JOBS=true
# Local-dev escape hatch ONLY. Forbidden in production (fail-closed at boot).
VALIDATE_TWILIO_SIGNATURE=true

# ── Supabase (SERVICE ROLE key — server-side only, bypasses RLS) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Founder admin (header-authed POST routes: /admin/user, /admin/reset-user).
# Sent as the `x-admin-key` HEADER, never in a URL/query string. Constant-time
# compared. Leave unset to disable all admin routes (they return 404).
ADMIN_KEY=pick-a-long-random-string

# Allow-list for POST /admin/reset-user (the safe per-user tester reset).
# Comma-separated phone numbers; any format. reset-user refuses any number NOT
# in this list. Leave empty to disable the reset tool entirely.
TESTER_PHONES=17869727469,15551234567
